{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["dub1"],
  "crons": [
    {
      "path": "/api/cron/bench?scope=all",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/refresh-rankings",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/sweep-stuck-jobs?hours=72",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/refresh-stripe-accounts",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/auto-complete-cycles",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 9 * * 5"
    },
    {
      "path": "/api/cron/reengage?limit=20&days=30",
      "schedule": "0 10 * * 2"
    }
  ]
}
