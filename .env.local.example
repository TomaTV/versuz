# Versuz — local env. Copy to .env.local and fill in.
# In V0 these are optional: the web app falls back to fixtures
# (src/lib/fixtures/seed.js) when they're absent.

# =============================================================================
# Bench mode — controls which judges run
# =============================================================================
# dev          — 3 Groq Llama models (free, 3000 RPD total)            $0
# v1-thrift    — DeepSeek V4 Flash agent + GPT-5 nano judge (direct)   0.81 €/jour
# v1           — Haiku 4.5 + DeepSeek V4 Flash + GPT-5 mini (direct)   2.50 €/jour
# or-thrift    — GPT-5 nano via OpenRouter (1 key only)                0.86 €/jour
# or-v1        — Haiku 4.5 + DeepSeek V4 Flash + GPT-5 mini (OR)      2.60 €/jour
# prod         — Opus 4.7 + Gemini 2.5 Pro free + Mistral free         ~3 €/jour
# gold         — Opus + GPT-5 + Gemini 2.5 Pro (full canonical)        ~9 €/jour
#
# Recommandé pour solo dev : `or-v1` (1 seule clé OpenRouter, 1 seul billing
# dashboard, 200+ modèles dispo, prompt cache ~82% hit).
BENCH_MODE=dev
NEXT_PUBLIC_BENCH_MODE=dev

# Slice the active judge ensemble. BENCH_JUDGE_COUNT=1 keeps only the first
# judge from the preset (3× fewer calls per output).
BENCH_JUDGE_COUNT=

# Concurrency hints for the bench runner
BENCH_AGENT_PROVIDER=
BENCH_AGENT_MODEL=
BENCH_BUDGET_USD=

# Judge output token limit (default 900). DeepSeek V4 Flash emits internal
# reasoning tokens before JSON — higher caps increase cost. Override to 500
# for aggressive cost saving, or 2500 if you encounter JSON truncation.
BENCH_JUDGE_MAX_TOKENS=

# =============================================================================
# Supabase (DB + auth)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# GitHub scraping (SKILL.md / CLAUDE.md)
# =============================================================================
# Required for `npm run scrape:*`. A read-scope fine-grained PAT is enough.
# https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=

# =============================================================================
# Free judges (BENCH_MODE=dev)
# =============================================================================
# Groq — 3 Llama models with separate per-model quotas (3000 RPD total).
# https://console.groq.com/keys
GROQ_API_KEY=

# Google AI Studio — Gemini 2.5 Flash. Free 1500 RPD.
# Used for task generation via `npm run generate-tasks`.
# https://aistudio.google.com/apikey
GOOGLE_AI_STUDIO_KEY=

# Mistral — Mistral Large 2. Free "Experiment plan".
# https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# =============================================================================
# Paid judges — option A: direct provider keys (5 separate accounts)
# =============================================================================
# Anthropic API for Haiku 4.5 / Sonnet 4.6 / Opus 4.7. Prompt caching is
# enabled by default in scripts/bench/providers/anthropic.mjs (~30% input
# discount when 3 judges hit the same skill within the 5min window).
# Prepay 5-10 € to start. https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API for GPT-5 mini / nano / GPT-5. Billing at platform.openai.com.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# DeepSeek V4 Flash / R1. Cheapest frontier reasoning model with prompt
# cache support on OpenRouter. https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# =============================================================================
# Paid judges — option B: OpenRouter (RECOMMENDED, single key)
# =============================================================================
# 200+ models behind one OpenAI-compatible endpoint, one billing dashboard,
# free tier models also available. ~5-15% markup over direct, traded for
# not babysitting 5 separate dashboards.
#
# With this single key set + BENCH_MODE=or-v1 you get Haiku 4.5 + DeepSeek V4 Flash
# + GPT-5 mini. With BENCH_MODE=or-thrift you get GPT-5 nano single judge.
#
# Prepay 10 € → ~4 days of full 100 skills × 5 tasks × 3 judges, or weeks of
# smaller test cycles.
#
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# =============================================================================
# Admin gate (GitHub OAuth + allowlist)
# =============================================================================
# Set either or both. ADMIN_GITHUB_IDS is preferred (immutable);
# ADMIN_GITHUB_LOGINS works but logins can be renamed/reclaimed.
# Find your numeric ID at https://api.github.com/users/<your-login> ("id").
ADMIN_GITHUB_IDS=
ADMIN_GITHUB_LOGINS=

# =============================================================================
# Cron / public site URL
# =============================================================================
# Vercel cron secret — needs to match the route handler check.
# Generate one : `openssl rand -hex 32` (any string ≥16 chars works).
CRON_SECRET=

# Public site URL — used for OG images, badge URLs in markdown copy, sitemap,
# RSS feeds. Falls back to https://versuz.dev if unset.
NEXT_PUBLIC_SITE_URL=
