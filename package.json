{
  "name": "versuz",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --max-http-header-size=32768 node_modules/next/dist/bin/next dev",
    "build": "next build",
    "start": "node --max-http-header-size=32768 node_modules/next/dist/bin/next start",
    "lint": "eslint",
    "format": "prettier --write \"src/**/*.{js,jsx,css,md,json}\"",
    "seed": "node scripts/seed.mjs",
    "seed:premium": "node scripts/seed-premium.mjs",
    "seed:vz-skills": "node scripts/seed-vz-skills.mjs",
    "reset:premium": "node scripts/reset-premium.mjs",
    "scrape:skills": "node scripts/scrape/index.mjs",
    "scrape:claude-md": "node scripts/scrape-claude-md/index.mjs",
    "scrape:aggregators": "node scripts/scrape-aggregators/index.mjs",
    "scrape:aggregators:skills": "node scripts/scrape-aggregators/index.mjs --kind=skill",
    "scrape:aggregators:claude-md": "node scripts/scrape-aggregators/index.mjs --kind=claude_md",
    "scrape:codesearch": "node scripts/scrape-codesearch/index.mjs",
    "scrape:codesearch:skills": "node scripts/scrape-codesearch/index.mjs --kind=skill",
    "scrape:codesearch:claude-md": "node scripts/scrape-codesearch/index.mjs --kind=claude_md",
    "scrape:max": "node scripts/scrape-codesearch/index.mjs --max",
    "reclassify": "node scripts/reclassify.mjs",
    "reclassify:other": "node scripts/reclassify.mjs --only-other",
    "scrape:all": "node scripts/scrape/index.mjs && node scripts/scrape-claude-md/index.mjs && node scripts/scrape-aggregators/index.mjs && node scripts/scrape-codesearch/index.mjs",
    "bench": "node scripts/bench/index.mjs",
    "bench:local": "node scripts/bench/local.mjs",
    "bench:smoke": "node scripts/bench/smoke.mjs",
    "bench:agent-smoke": "node scripts/bench/agent-smoke.mjs",
    "bench:seed-tasks": "node scripts/bench/seed-tasks.mjs",
    "bench:enqueue": "node scripts/bench/enqueue-cycle.mjs",
    "bench:quality": "node scripts/bench/quality-judge.mjs",
    "bench:tiered": "node scripts/bench/tiered.mjs",
    "bench:full": "node scripts/bench/full.mjs",
    "generate-tasks": "node scripts/generate-tasks.mjs"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4"
  }
}
